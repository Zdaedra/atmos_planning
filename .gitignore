# ============================================================
# Atmos Planning — root .gitignore
# Principle: Git stores ONLY source code.
# Business data, AI workspace metadata, secrets stay local on
# Mac / Hetzner / Notion / Drive depending on the data type.
# ============================================================

# --- AI workspace metadata (Claude Code local memory) ---
# Memory Bank, raw Drive dumps, wording vault, summaries —
# personal context for AI agents, lives locally only.
.claude/

# --- Environment & secrets ---
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
client_secret*.json
oauth_token*.json
service_account*.json

# --- Databases (production data lives on Hetzner) ---
*.db
*.sqlite
*.sqlite3
backend/atmos_planning.db

# --- Logs ---
*.log
backend/backend.log
logs/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.venv/
venv/
env/

# --- Node / Frontend (frontends have own .gitignore, but just in case) ---
node_modules/
.next/
dist/
build/

# --- OS / Editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# --- Debug artifacts (committed historically, but should be gitignored going forward) ---
# Keep existing ones for now but block new ones via pattern:
debug_*.html
debug_*.png
# (Existing bot_error*.png stays as already tracked)

# --- AI tooling / scratch ---
.aider*
.cursor/

# --- One-off dev/admin/seed scripts (contain hardcoded test credentials) ---
# These are not production code — they're throw-away scripts for local debugging
# and seeding. They contain test passwords like "pass123" and shouldn't ship.
# Real admin / seed should live under scripts/ with env-var configuration.
/create_admin.py
/dump_tasks.py
/openai_consult.py
/patch_docker.py
/query_users.py
/take_screenshots.py
/test_api.py
/test_timezone.py
/backend/add_alexey.py
/backend/alter_db.py
/backend/alter_db2.py
/backend/check_bug.py
/backend/check_bug2.py
/backend/fix_shifts.py
/backend/retroactive_tasks.py
/backend/rewrite_tz.py
