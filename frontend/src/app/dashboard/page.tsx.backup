"use client";

import { useState, useEffect } from "react";
import { Play, CheckCircle2, User, Clock, MapPin, Camera, CheckSquare, ChevronRight, MessageSquare, Calendar } from "lucide-react";

type TaskTemplate = {
    name: string;
    description: string;
    repeat_type: string;
    time_of_day: string;
    photo_required: boolean;
};

type Task = {
    id: number;
    template_id: number;
    zone_id: number;
    status: string;
    scheduled_date?: string;
    template?: TaskTemplate;
    photos?: any[];
    comments?: any[];
};

export default function SupervisorDashboard() {
    const [tasks, setTasks] = useState<Task[]>([]);
    const [loading, setLoading] = useState(true);
    const [viewingTask, setViewingTask] = useState<Task | null>(null);
    const [comment, setComment] = useState("");
    const [user, setUser] = useState<any>(null);
    const [fullScreenImage, setFullScreenImage] = useState<string | null>(null);

    // Phase 34: Calendar Mode States
    const [dashboardMode, setDashboardMode] = useState<"today" | "calendar">("today");
    const [selectedFutureDate, setSelectedFutureDate] = useState<string>(new Date().toISOString().split('T')[0]);
    const [templates, setTemplates] = useState<TaskTemplate[]>([]);

    // Poll for tasks and check active shift
    useEffect(() => {
        const loadDashboardData = async () => {
            const token = localStorage.getItem("access_token");
            if (!token) {
                window.location.href = "/";
                return;
            }

            try {
                // 1. Fetch User Profile
                const userRes = await fetch("http://89.167.122.76:4080/auth/me", {
                    headers: { "Authorization": `Bearer ${token}` }
                });

                if (!userRes.ok) {
                    localStorage.removeItem("access_token");
                    window.location.href = "/";
                    return;
                }
                const userData = await userRes.json();
                setUser(userData);

                // 2. Fetch Tasks using true User ID
                const tasksRes = await fetch(`http://89.167.122.76:4080/tasks/user/${userData.id}`);
                if (tasksRes.ok) {
                    setTasks(await tasksRes.json());
                }

                // 3. Fetch Templates for Calendar Simulation
                const defaultTemplatesRes = await fetch(`http://89.167.122.76:4080/tasks/templates/`);
                if (defaultTemplatesRes.ok) {
                    setTemplates(await defaultTemplatesRes.json());
                }
            } catch (e) {
                console.error("Failed to load dashboard data", e);
            } finally {
                setLoading(false);
            }
        };

        loadDashboardData();

        const interval = setInterval(() => {
            if (user && user.id) {
                fetch(`http://89.167.122.76:4080/tasks/user/${user.id}`)
                    .then(r => r.json())
                    .then(data => setTasks(data))
                    .catch(e => console.error(e));
            }
        }, 15000);
        return () => clearInterval(interval);
    }, [user?.id]);

    const [uploading, setUploading] = useState<number | null>(null);

    const handlePhotoUpload = async (e: React.ChangeEvent<HTMLInputElement>, taskId: number, zoneId: number) => {
        const file = e.target.files?.[0];
        if (!file) return;

        setUploading(taskId);
        try {
            const formData = new FormData();
            formData.append("file", file);

            // POST to existing backend Media route
            const res = await fetch(`http://89.167.122.76:4080/media/upload?task_id=${taskId}&user_id=${user?.id || 1}&zone_id=${zoneId}`, {
                method: "POST",
                body: formData
            });

            if (res.ok) {
                const data = await res.json();
                const newPhoto = {
                    id: data.id,
                    url: data.url,
                    task_id: taskId
                };

                // Update the open modal immediately
                if (viewingTask && viewingTask.id === taskId) {
                    setViewingTask({
                        ...viewingTask,
                        photos: [...(viewingTask.photos || []), newPhoto]
                    });
                }

                // Update background array
                setTasks(prev => prev.map(t => {
                    if (t.id === taskId) {
                        return { ...t, photos: [...(t.photos || []), newPhoto] };
                    }
                    return t;
                }));
                // alert("Photo uploaded successfully!");
            } else {
                alert("Failed to upload photo.");
            }
        } catch (error) {
            console.error("Upload error", error);
        } finally {
            setUploading(null);
        }
    };

    const handleMarkDone = async (taskId: number) => {
        try {
            const queryParams = new URLSearchParams([["status", "Completed"]]);
            if (comment && comment.trim()) {
                queryParams.append("comment", comment.trim());
            }

            const res = await fetch(`http://89.167.122.76:4080/tasks/${taskId}/status?${queryParams.toString()}`, { method: "PATCH" });
            if (res.ok) {
                setTasks(tasks.map(t => t.id === taskId ? { ...t, status: "Completed" } : t));
                setViewingTask(null);
                setComment("");
            } else {
                alert("Failed to complete task.");
            }
        } catch (e) {
            console.error(e);
        }
    };

    const handleDeletePhoto = async (photoId: number, taskId: number) => {
        if (!confirm("Are you sure you want to delete this photo?")) return;

        try {
            const res = await fetch(`http://89.167.122.76:4080/media/upload/${photoId}`, {
                method: "DELETE"
            });

            if (res.ok) {
                // Remove from active modal
                if (viewingTask && viewingTask.id === taskId) {
                    setViewingTask({
                        ...viewingTask,
                        photos: viewingTask.photos?.filter((p: any) => p.id !== photoId) || []
                    });
                }

                // Remove from background tasks array
                setTasks(prev => prev.map(t => {
                    if (t.id === taskId) {
                        return { ...t, photos: t.photos?.filter((p: any) => p.id !== photoId) || [] };
                    }
                    return t;
                }));
            } else {
                alert("Failed to delete photo.");
            }
        } catch (e) {
            console.error("Delete photo error", e);
        }
    };

    if (loading) {
        return (
            <div className="auth-container">
                <div className="loading-spinner"></div>
            </div>
        );
    }

    const overdueTasks = tasks.filter(t => t.status === "Overdue" || (t.status === "Pending" && t.scheduled_date && new Date(t.scheduled_date).setHours(0, 0, 0, 0) < new Date().setHours(0, 0, 0, 0)));
    const completedTasks = tasks.filter(t => t.status === "Completed");
    const dailyTasks = tasks.filter(t => t.status !== "Completed" && t.status !== "Overdue" && t.template?.repeat_type === 'daily');
    const plannedTasks = tasks.filter(t => t.status !== "Completed" && t.status !== "Overdue" && t.template?.repeat_type !== 'daily' && t.template?.repeat_type !== 'project');
    const projectTasks = tasks.filter(t => t.status !== "Completed" && t.status !== "Overdue" && t.template?.repeat_type === 'project');

    // Calendar Simulation Math
    const futureDateObj = new Date(selectedFutureDate);
    const simulatedTasksForDate = templates.filter(t => {
        const rpt = (t.repeat_type || "daily").toLowerCase();

        // Daily happens every single day
        if (rpt === 'daily') return true;

        // Missing anchor date? Can't simulate
        const anchorDateStr = (t as any).next_execution_date;
        if (!anchorDateStr) return false;

        const anchorD = new Date(anchorDateStr);
        // Normalize times to midnight for clean comparison
        const futureTime = new Date(futureDateObj.getFullYear(), futureDateObj.getMonth(), futureDateObj.getDate()).getTime();
        const anchorTime = new Date(anchorD.getFullYear(), anchorD.getMonth(), anchorD.getDate()).getTime();

        if (rpt === 'project') {
            return anchorD.getDate() === futureDateObj.getDate() &&
                anchorD.getMonth() === futureDateObj.getMonth() &&
                anchorD.getFullYear() === futureDateObj.getFullYear();
        }

        if (rpt === 'weekly') {
            return futureTime >= anchorTime && futureDateObj.getDay() === anchorD.getDay();
        }

        if (rpt === 'biweekly') {
            if (futureTime < anchorTime || futureDateObj.getDay() !== anchorD.getDay()) return false;
            const msPerWeek = 7 * 24 * 60 * 60 * 1000;
            const diffWeeks = Math.floor((futureTime - anchorTime) / msPerWeek);
            return diffWeeks >= 0 && diffWeeks % 2 === 0;
        }

        if (rpt === 'monthly') {
            return futureTime >= anchorTime && futureDateObj.getDate() === anchorD.getDate();
        }

        return false;
    });

    const simDaily = simulatedTasksForDate.filter(t => (t.repeat_type || "daily").toLowerCase() === 'daily');
    const simPlanned = simulatedTasksForDate.filter(t => ["weekly", "biweekly", "monthly"].includes((t.repeat_type || "").toLowerCase()));
    const simProject = simulatedTasksForDate.filter(t => (t.repeat_type || "").toLowerCase() === 'project');

    return (
        <div style={{ maxWidth: "800px", margin: "0 auto", padding: "24px" }}>
            <header style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: "16px", background: "var(--card)", padding: "16px 24px", borderRadius: "16px", boxShadow: "0 4px 6px -1px rgba(0,0,0,0.05)" }}>
                <div style={{ display: "flex", alignItems: "center", gap: "12px" }}>
                    <div style={{ background: "var(--primary)", padding: "10px", borderRadius: "50%", color: "white" }}>
                        <User size={24} />
                    </div>
                    <div>
                        <h2 style={{ margin: "0", fontSize: "18px", textTransform: "capitalize" }}>{user ? `${user.name}, ${user.role}` : "Loading..."}</h2>
                        <p style={{ margin: "0", fontSize: "14px", color: "var(--primary)" }}>🟢 On Duty</p>
                    </div>
                </div>
            </header>

            <div style={{ display: "flex", gap: "8px", marginBottom: "24px", background: "var(--card)", padding: "8px", borderRadius: "12px", border: "1px solid var(--border)" }}>
                <button
                    onClick={() => { setDashboardMode("today"); setViewingTask(null); }}
                    style={{ flex: 1, padding: "12px", borderRadius: "8px", border: "none", background: dashboardMode === "today" ? "var(--primary)" : "transparent", color: dashboardMode === "today" ? "white" : "var(--foreground)", fontWeight: "bold", cursor: "pointer", transition: "all 0.2s" }}
                >
                    Today
                </button>
                <button
                    onClick={() => { setDashboardMode("calendar"); setViewingTask(null); }}
                    style={{ flex: 1, padding: "12px", borderRadius: "8px", border: "none", background: dashboardMode === "calendar" ? "var(--primary)" : "transparent", color: dashboardMode === "calendar" ? "white" : "var(--foreground)", fontWeight: "bold", cursor: "pointer", transition: "all 0.2s" }}
                >
                    Calendar
                </button>
            </div>

            <div style={{ animation: "fadeIn 0.5s ease" }}>
                {dashboardMode === "calendar" && (
                    <div style={{ display: "flex", flexDirection: "column", gap: "24px" }}>
                        <div style={{ background: "var(--card)", padding: "16px", borderRadius: "16px", border: "1px solid var(--border)", display: "flex", alignItems: "center", gap: "16px" }}>
                            <Calendar size={24} color="var(--primary)" />
                            <div style={{ flex: 1 }}>
                                <label style={{ display: "block", fontSize: "12px", color: "#64748b", fontWeight: "bold", textTransform: "uppercase", marginBottom: "4px" }}>Select Date</label>
                                <input
                                    type="date"
                                    value={selectedFutureDate}
                                    onChange={(e) => setSelectedFutureDate(e.target.value)}
                                    style={{ width: "100%", padding: "8px", borderRadius: "8px", border: "1px solid var(--border)", fontSize: "16px", fontFamily: "inherit" }}
                                />
                            </div>
                        </div>

                        {simulatedTasksForDate.length === 0 ? (
                            <div style={{ textAlign: "center", padding: "40px", color: "var(--muted)", background: "var(--card)", borderRadius: "16px", border: "1px solid var(--border)" }}>
                                <Calendar size={48} style={{ opacity: 0.2, margin: "0 auto 16px ", display: "block" }} />
                                <p>No organizational rules are currently scheduled to intersect with this date.</p>
                            </div>
                        ) : (
                            <div style={{ display: "flex", flexDirection: "column", gap: "16px" }}>
                                <h3 style={{ margin: "0 0 8px 0", fontSize: "18px", color: "var(--foreground)" }}>Simulated Schedule</h3>

                                {simDaily.length > 0 && (
                                    <div>
                                        <h4 style={{ margin: "0 0 8px 0", fontSize: "14px", color: "#64748b", textTransform: "uppercase", display: "flex", alignItems: "center", gap: "8px" }}><CheckSquare size={16} /> Daily</h4>
                                        <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
                                            {simDaily.map(t => (
                                                <div key={`sim-${t.name}`} style={{ background: "var(--card)", padding: "16px", borderRadius: "12px", border: "1px solid var(--border)", opacity: 0.8 }}>
                                                    <h4 style={{ margin: "0 0 4px 0", fontSize: "16px" }}>{t.name}</h4>
                                                    <span style={{ fontSize: "12px", color: "#64748b", display: "flex", alignItems: "center", gap: "4px" }}><Clock size={12} /> {t.time_of_day || "Anytime"}</span>
                                                </div>
                                            ))}
                                        </div>
                                    </div>
                                )}

                                {simPlanned.length > 0 && (
                                    <div style={{ marginTop: "16px" }}>
                                        <h4 style={{ margin: "0 0 8px 0", fontSize: "14px", color: "#8b5cf6", textTransform: "uppercase", display: "flex", alignItems: "center", gap: "8px" }}><CheckSquare size={16} /> Planned</h4>
                                        <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
                                            {simPlanned.map(t => (
                                                <div key={`sim-${t.name}`} style={{ background: "var(--card)", padding: "16px", borderRadius: "12px", border: "1px solid #ede9fe", opacity: 0.8 }}>
                                                    <h4 style={{ margin: "0 0 4px 0", fontSize: "16px" }}>{t.name}</h4>
                                                    <span style={{ fontSize: "12px", color: "#64748b", display: "flex", alignItems: "center", gap: "4px" }}><Clock size={12} /> {t.time_of_day || "Anytime"} (Rule: {t.repeat_type})</span>
                                                </div>
                                            ))}
                                        </div>
                                    </div>
                                )}

                                {simProject.length > 0 && (
                                    <div style={{ marginTop: "16px" }}>
                                        <h4 style={{ margin: "0 0 8px 0", fontSize: "14px", color: "#f59e0b", textTransform: "uppercase", display: "flex", alignItems: "center", gap: "8px" }}><CheckSquare size={16} /> Projects</h4>
                                        <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
                                            {simProject.map(t => (
                                                <div key={`sim-${t.name}`} style={{ background: "var(--card)", padding: "16px", borderRadius: "12px", border: "1px solid #fef3c7", opacity: 0.8 }}>
                                                    <h4 style={{ margin: "0 0 4px 0", fontSize: "16px" }}>{t.name}</h4>
                                                    <span style={{ fontSize: "12px", color: "#64748b", display: "flex", alignItems: "center", gap: "4px" }}><Clock size={12} /> {t.time_of_day || "Anytime"}</span>
                                                </div>
                                            ))}
                                        </div>
                                    </div>
                                )}
                            </div>
                        )}
                    </div>
                )}

                {dashboardMode === "today" && viewingTask ? (
                    <div style={{ background: "var(--card)", padding: "24px", borderRadius: "16px", border: "1px solid var(--border)", boxShadow: "0 10px 15px -3px rgba(0,0,0,0.1)" }}>
                        <button onClick={() => { setViewingTask(null); setComment("") }} style={{ background: "none", border: "none", color: "#64748b", cursor: "pointer", display: "flex", alignItems: "center", gap: "8px", marginBottom: "24px", fontWeight: "600", padding: 0 }}>
                            <ChevronRight size={20} style={{ transform: "rotate(180deg)" }} /> Back to Operations
                        </button>

                        <h2 style={{ fontSize: "24px", margin: "0 0 12px 0" }}>{viewingTask.template?.name || `Custom Task #${viewingTask.id}`}</h2>
                        <p style={{ fontSize: "16px", color: "#64748b", margin: "0 0 24px 0", lineHeight: "1.5" }}>
                            {viewingTask.template?.description || "No specific instructions provided for this task."}
                        </p>

                        <div style={{ display: "grid", gridTemplateColumns: "1fr", gap: "16px", marginBottom: "24px" }}>
                            <div style={{ background: "var(--background)", padding: "16px", borderRadius: "12px" }}>
                                <span style={{ display: "block", fontSize: "12px", color: "#64748b", textTransform: "uppercase", fontWeight: "bold", marginBottom: "4px" }}>When</span>
                                <span style={{ fontSize: "16px", fontWeight: "500", textTransform: "capitalize" }}>{viewingTask.template?.time_of_day || "Anytime"}</span>
                            </div>
                        </div>

                        {viewingTask.status === "Completed" ? (
                            <div style={{ borderTop: "1px solid var(--border)", paddingTop: "24px", display: "flex", flexDirection: "column", gap: "16px" }}>
                                <h3 style={{ fontSize: "16px", marginBottom: "0px", display: "flex", alignItems: "center", gap: "8px" }}><CheckCircle2 size={18} color="var(--success)" /> Completion Report</h3>
                                {viewingTask.photos && viewingTask.photos.length > 0 && (
                                    <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
                                        {viewingTask.photos.map(photo => {
                                            const url = photo.url.startsWith('http') ? photo.url.replace('localhost:4000', '89.167.122.76:4000') : `http://89.167.122.76:4080${photo.url}`;
                                            return (
                                                <img
                                                    key={photo.id}
                                                    src={url}
                                                    style={{ width: "100%", borderRadius: "12px", border: "1px solid var(--border)", objectFit: "cover", cursor: "pointer" }}
                                                    alt="Task complete"
                                                    onClick={() => setFullScreenImage(url)}
                                                />
                                            );
                                        })}
                                    </div>
                                )}
                                {viewingTask.comments && viewingTask.comments.length > 0 && (
                                    <div style={{ background: "var(--background)", padding: "16px", borderRadius: "8px", border: "1px solid var(--border)", color: "var(--text)" }}>
                                        <p style={{ margin: 0, fontStyle: "italic" }}>"{viewingTask.comments[0].text}"</p>
                                    </div>
                                )}
                                {(!viewingTask.photos || viewingTask.photos.length === 0) && (!viewingTask.comments || viewingTask.comments.length === 0) && (
                                    <p style={{ color: "var(--muted)" }}>No photo or comments were attached.</p>
                                )}
                            </div>
                        ) : (
                            <div style={{ borderTop: "1px solid var(--border)", paddingTop: "24px", display: "flex", flexDirection: "column", gap: "16px" }}>
                                <label style={{ display: "flex", flexDirection: "column", gap: "8px", fontWeight: "bold" }}>
                                    <span style={{ display: "flex", alignItems: "center", gap: "8px" }}><MessageSquare size={18} /> Add Comment </span>
                                    <textarea
                                        placeholder="Note any issues or observations..."
                                        value={comment}
                                        onChange={(e) => setComment(e.target.value)}
                                        style={{ padding: "12px", borderRadius: "8px", border: "1px solid var(--border)", minHeight: "80px", fontFamily: "inherit", width: "100%" }}
                                    />
                                </label>

                                {viewingTask.photos && viewingTask.photos.length > 0 && (
                                    <div style={{ marginTop: "8px", marginBottom: "8px", display: "flex", flexDirection: "column", gap: "8px" }}>
                                        <p style={{ margin: "0", fontSize: "14px", fontWeight: "bold", color: "var(--foreground)" }}>Attached Photo(s):</p>
                                        {viewingTask.photos.map(photo => {
                                            const url = photo.url.startsWith('http') ? photo.url.replace('localhost:4000', '89.167.122.76:4000') : `http://89.167.122.76:4080${photo.url}`;
                                            return (
                                                <div key={photo.id} style={{ position: "relative" }}>
                                                    <img
                                                        src={url}
                                                        style={{ width: "100%", borderRadius: "12px", border: "1px solid var(--border)", objectFit: "cover", maxHeight: "250px", cursor: "pointer" }}
                                                        alt="Task attachment"
                                                        onClick={() => setFullScreenImage(url)}
                                                    />
                                                    <button
                                                        onClick={(e) => { e.stopPropagation(); handleDeletePhoto(photo.id, viewingTask.id); }}
                                                        style={{ position: "absolute", top: "8px", right: "8px", background: "rgba(0,0,0,0.5)", color: "white", border: "none", borderRadius: "50%", width: "32px", height: "32px", display: "flex", justifyContent: "center", alignItems: "center", cursor: "pointer" }}
                                                    >
                                                        ✕
                                                    </button>
                                                </div>
                                            );
                                        })}
                                    </div>
                                )}

                                <div style={{ display: "flex", gap: "12px", marginTop: "16px" }}>
                                    <label style={{
                                        flex: 1,
                                        background: uploading === viewingTask.id ? "var(--muted)" : "var(--background)",
                                        color: "var(--foreground)",
                                        border: "1px solid var(--border)",
                                        padding: "16px",
                                        borderRadius: "12px",
                                        cursor: uploading === viewingTask.id ? "not-allowed" : "pointer",
                                        fontWeight: "bold",
                                        display: "flex",
                                        justifyContent: "center",
                                        alignItems: "center",
                                        gap: "8px",
                                        textAlign: "center"
                                    }}>
                                        <Camera size={20} />
                                        {uploading === viewingTask.id ? "Uploading..." : "Add Photo"}
                                        <input
                                            type="file"
                                            accept="image/*"
                                            capture="environment"
                                            hidden
                                            onChange={(e) => handlePhotoUpload(e, viewingTask.id, viewingTask.zone_id)}
                                            disabled={uploading === viewingTask.id}
                                        />
                                    </label>

                                    <button
                                        onClick={() => handleMarkDone(viewingTask.id)}
                                        className="btn-primary"
                                        style={{ flex: 1, padding: "16px", fontSize: "16px", display: "flex", justifyContent: "center", alignItems: "center", gap: "8px", border: "none" }}
                                    >
                                        <CheckCircle2 size={20} /> Complete
                                    </button>
                                </div>
                            </div>
                        )}
                    </div>
                ) : dashboardMode === "today" && !viewingTask ? (
                    <div style={{ display: "flex", flexDirection: "column", gap: "32px" }}>
                        {/* COMPLETED SECTION (MOVED TO TOP) */}
                        {completedTasks.length > 0 && (
                            <details style={{ background: "transparent", padding: "0 16px" }}>
                                <summary style={{ fontSize: "18px", marginBottom: "16px", display: "flex", alignItems: "center", gap: "8px", color: "#64748b", cursor: "pointer", listStyle: "none" }}>
                                    <CheckCircle2 color="#64748b" /> Completed Today <span style={{ background: "#f1f5f9", padding: "2px 8px", borderRadius: "12px", fontSize: "12px", fontWeight: "bold" }}>{completedTasks.length}</span> <ChevronRight size={20} style={{ marginLeft: "auto", transform: "rotate(90deg)" }} />
                                </summary>
                                <div style={{ display: "flex", flexDirection: "column", gap: "12px", marginTop: "16px" }}>
                                    {completedTasks.map(task => {
                                        const firstPhoto = task.photos && task.photos.length > 0 ? task.photos[0] : null;
                                        const thumbUrl = firstPhoto ? (firstPhoto.url.startsWith('http') ? firstPhoto.url.replace('localhost:4000', '89.167.122.76:4000') : `http://89.167.122.76:4080${firstPhoto.url}`) : null;
                                        return (
                                            <div
                                                key={`completed-${task.id}`}
                                                onClick={() => setViewingTask(task)}
                                                style={{
                                                    background: "var(--card)",
                                                    padding: "16px",
                                                    borderRadius: "12px",
                                                    border: "1px solid var(--border)",
                                                    display: "flex",
                                                    justifyContent: "space-between",
                                                    alignItems: "center",
                                                    opacity: 0.7,
                                                    cursor: "pointer",
                                                    transition: "opacity 0.2s"
                                                }}
                                                className="hover-card"
                                            >
                                                <div style={{ display: "flex", alignItems: "center", gap: "12px", textDecoration: "line-through", color: "#64748b" }}>
                                                    <CheckCircle2 size={20} color="var(--success)" />
                                                    <h4 style={{ margin: "0", fontSize: "16px", fontWeight: "normal" }}>
                                                        {task.template?.name || `Custom Task #${task.id}`}
                                                    </h4>
                                                </div>
                                                {thumbUrl && (
                                                    <img src={thumbUrl} alt="Thumbnail" style={{ width: "40px", height: "40px", borderRadius: "8px", objectFit: "cover" }} />
                                                )}
                                            </div>
                                        );
                                    })}
                                </div>
                            </details>
                        )}

                        {/* OVERDUE */}
                        {overdueTasks.length > 0 && (
                            <details style={{ background: "var(--card)", padding: "16px", borderRadius: "16px", border: "1px solid var(--border)" }}>
                                <summary style={{ fontSize: "20px", fontWeight: "bold", cursor: "pointer", listStyle: "none", display: "flex", alignItems: "center", gap: "12px", color: "var(--danger)" }}>
                                    <Clock size={24} /> Overdue Tasks <span style={{ background: "#fee2e2", color: "var(--danger)", padding: "2px 8px", borderRadius: "12px", fontSize: "12px" }}>{overdueTasks.length}</span> <ChevronRight size={20} style={{ marginLeft: "auto", transform: "rotate(90deg)" }} />
                                </summary>
                                <div style={{ display: "flex", flexDirection: "column", gap: "12px", marginTop: "16px" }}>
                                    {overdueTasks.map(task => (
                                        <div key={`overdue-${task.id}`} onClick={() => setViewingTask(task)} style={{ background: "var(--background)", padding: "16px", borderRadius: "12px", border: "1px solid var(--danger)", borderLeft: "4px solid var(--danger)", display: "flex", justifyContent: "space-between", alignItems: "center", cursor: "pointer" }}>
                                            <div>
                                                <h4 style={{ margin: "0 0 4px 0", fontSize: "16px" }}>{task.template?.name || `Custom Task #${task.id}`}</h4>
                                                <span style={{ fontSize: "12px", color: "var(--danger)", fontWeight: "bold" }}>Was Due: {task.template?.time_of_day || "Anytime"}</span>
                                            </div>
                                            <ChevronRight size={20} color="#64748b" />
                                        </div>
                                    ))}
                                </div>
                            </details>
                        )}

                        {/* DAILY TODAY */}
                        <details style={{ background: "var(--card)", padding: "16px", borderRadius: "16px", border: "1px solid var(--border)" }}>
                            <summary style={{ fontSize: "20px", fontWeight: "bold", cursor: "pointer", listStyle: "none", display: "flex", alignItems: "center", gap: "12px" }}>
                                <CheckSquare size={24} className="text-primary" /> Daily Operations <span style={{ background: "#f1f5f9", color: "#64748b", padding: "2px 8px", borderRadius: "12px", fontSize: "12px" }}>{dailyTasks.length}</span> <ChevronRight size={20} style={{ marginLeft: "auto", transform: "rotate(90deg)" }} />
                            </summary>
                            <div style={{ display: "flex", flexDirection: "column", gap: "12px", marginTop: "16px" }}>
                                {dailyTasks.map(task => (
                                    <div key={`daily-${task.id}`} onClick={() => setViewingTask(task)} style={{ background: "var(--background)", padding: "16px", borderRadius: "12px", border: "1px solid var(--border)", display: "flex", justifyContent: "space-between", alignItems: "center", cursor: "pointer" }}>
                                        <div>
                                            <h4 style={{ margin: "0 0 4px 0", fontSize: "16px" }}>{task.template?.name || `Custom Task #${task.id}`}</h4>
                                            <span style={{ fontSize: "12px", color: "#64748b", display: "flex", alignItems: "center", gap: "4px" }}><Clock size={12} /> {task.template?.time_of_day || "Anytime"}</span>
                                        </div>
                                        <ChevronRight size={20} color="#64748b" />
                                    </div>
                                ))}
                                {dailyTasks.length === 0 && (
                                    <p style={{ color: "#64748b", fontSize: "14px", margin: 0, textAlign: "center", padding: "16px" }}>All daily operations completed!</p>
                                )}
                            </div>
                        </details>

                        {/* PLANNED TODAY */}
                        <details style={{ background: "var(--card)", padding: "16px", borderRadius: "16px", border: "1px solid var(--border)" }}>
                            <summary style={{ fontSize: "20px", fontWeight: "bold", cursor: "pointer", listStyle: "none", display: "flex", alignItems: "center", gap: "12px" }}>
                                <CheckSquare size={24} color="#8b5cf6" /> Planned Today <span style={{ background: "#ede9fe", color: "#8b5cf6", padding: "2px 8px", borderRadius: "12px", fontSize: "12px" }}>{plannedTasks.length}</span> <ChevronRight size={20} style={{ marginLeft: "auto", transform: "rotate(90deg)" }} />
                            </summary>
                            <div style={{ display: "flex", flexDirection: "column", gap: "12px", marginTop: "16px" }}>
                                {plannedTasks.map(task => (
                                    <div key={`planned-${task.id}`} onClick={() => setViewingTask(task)} style={{ background: "var(--background)", padding: "16px", borderRadius: "12px", border: "1px solid var(--border)", display: "flex", justifyContent: "space-between", alignItems: "center", cursor: "pointer" }}>
                                        <div>
                                            <h4 style={{ margin: "0 0 4px 0", fontSize: "16px" }}>{task.template?.name || `Custom Task #${task.id}`}</h4>
                                            <span style={{ fontSize: "12px", color: "#64748b", display: "flex", alignItems: "center", gap: "4px" }}><Clock size={12} /> {task.template?.time_of_day || "Anytime"}</span>
                                        </div>
                                        <ChevronRight size={20} color="#64748b" />
                                    </div>
                                ))}
                                {plannedTasks.length === 0 && (
                                    <p style={{ color: "#64748b", fontSize: "14px", margin: 0, textAlign: "center", padding: "16px" }}>No extra planned operations today.</p>
                                )}
                            </div>
                        </details>

                        {/* PROJECTS */}
                        <details style={{ background: "var(--card)", padding: "16px", borderRadius: "16px", border: "1px solid var(--border)" }}>
                            <summary style={{ fontSize: "20px", fontWeight: "bold", cursor: "pointer", listStyle: "none", display: "flex", alignItems: "center", gap: "12px" }}>
                                <CheckSquare size={24} color="#f59e0b" /> Projects <span style={{ background: "#fef3c7", color: "#d97706", padding: "2px 8px", borderRadius: "12px", fontSize: "12px" }}>{projectTasks.length}</span> <ChevronRight size={20} style={{ marginLeft: "auto", transform: "rotate(90deg)" }} />
                            </summary>
                            <div style={{ display: "flex", flexDirection: "column", gap: "12px", marginTop: "16px" }}>
                                {projectTasks.map(task => (
                                    <div key={`project-${task.id}`} onClick={() => setViewingTask(task)} style={{ background: "var(--background)", padding: "16px", borderRadius: "12px", border: "1px solid var(--border)", display: "flex", justifyContent: "space-between", alignItems: "center", cursor: "pointer" }}>
                                        <div>
                                            <h4 style={{ margin: "0 0 4px 0", fontSize: "16px" }}>{task.template?.name || `Custom Task #${task.id}`}</h4>
                                            <span style={{ fontSize: "12px", color: "#64748b", display: "flex", alignItems: "center", gap: "4px" }}><Clock size={12} /> {task.template?.time_of_day || "Anytime"}</span>
                                        </div>
                                        <ChevronRight size={20} color="#64748b" />
                                    </div>
                                ))}
                                {projectTasks.length === 0 && (
                                    <p style={{ color: "#64748b", fontSize: "14px", margin: 0, textAlign: "center", padding: "16px" }}>No active projects.</p>
                                )}
                            </div>
                        </details>
                    </div>
                ) : null}
            </div>
            {fullScreenImage && (
                <div
                    onClick={() => setFullScreenImage(null)}
                    style={{
                        position: "fixed",
                        top: 0, left: 0, right: 0, bottom: 0,
                        background: "rgba(0,0,0,0.9)",
                        zIndex: 9999,
                        display: "flex",
                        justifyContent: "center",
                        alignItems: "center",
                        padding: "24px",
                        cursor: "zoom-out"
                    }}
                >
                    <img
                        src={fullScreenImage}
                        style={{ maxWidth: "100%", maxHeight: "100%", objectFit: "contain", borderRadius: "8px" }}
                        alt="Full screen"
                        onClick={(e) => e.stopPropagation()}
                    />
                    <button
                        onClick={() => setFullScreenImage(null)}
                        style={{ position: "absolute", top: "24px", right: "24px", background: "none", border: "none", color: "white", fontSize: "32px", cursor: "pointer" }}
                    >
                        ✕
                    </button>
                </div>
            )}
        </div>
    );
}
